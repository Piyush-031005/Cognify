# Cognify v3.0 Production Environment Variables Config Template

# App port
PORT=10000

# Secret key for JWT HMAC token signatures (change to a cryptographically secure key)
COGNIFY_SECRET_KEY=production_env_secret_key_change_me_987654321

# Access bypass override for regression testing (set to false in production)
COGNIFY_BYPASS_AUTH=false

# SQLite Database Location path (default: cognify.db in workspace root)
DATABASE_URL=cognify.db

# Git commit and release tag details
GIT_COMMIT=684f090
RELEASE_TAG=v3.0.0
